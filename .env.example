# Demo login (optional — defaults match Alex Rivera in src/config/demoCredentials.ts)
VITE_DEMO_USERNAME=alex.rivera@reign.os
VITE_DEMO_PASSWORD=demo1234

# Job site geofence (optional — defaults to Downtown Job Site in DashboardPage)
# VITE_JOB_SITE_LAT=43.052639
# VITE_JOB_SITE_LNG=-87.896407
# VITE_JOB_SITE_NAME=Downtown Job Site

# Pin employee location at the job site for clock-in/out testing (boolean)
VITE_OVERRIDE_EMPLOYEE_LOCATION=true

# Skip geofence check entirely without faking GPS (boolean, optional)
# VITE_BYPASS_GEOFENCE=true

# Force re-seed shift templates from MOCK_SHIFTS (boolean, optional)
# VITE_SHIFT_TEST=true
